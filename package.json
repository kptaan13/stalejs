{
  "name": "stalejs",
  "version": "0.1.1",
  "description": "Zero-dependency DOM content-freshness primitive. Keeps elements up to date automatically.",
  "keywords": [
    "stale",
    "stalejs",
    "polling",
    "refetch",
    "dom",
    "freshness",
    "ttl",
    "cache",
    "javascript",
    "typescript"
  ],
  "author": "RK",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kptaan13/stalejs"
  },
  "homepage": "https://kptaan13.github.io/stalejs",
  "bugs": {
    "url": "https://github.com/kptaan13/stalejs/issues"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
